ADMIN_LOGIN_USER=admin
ADMIN_PASSWORD=change-me
ADMIN_SESSION_TOKEN=change-me
ADMIN_COOKIE_SECURE=false

# Neon / Postgres connection string (do not commit real credentials).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Stripe (do not commit real keys).
STRIPE_SECRET_KEY=change-me
STRIPE_WEBHOOK_SECRET=change-me

# Your deployed site URL (used for Stripe redirect URLs, etc.).
APP_URL=http://localhost:3000

# Where appointment / measurement requests should be emailed.
APPOINTMENT_NOTIFY_EMAIL=info@lustreview.com
